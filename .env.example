# Frontend public settings
# For a same-domain Vercel deploy, leave this unset or use /api.
NEXT_PUBLIC_API_URL=/api
# For local split frontend/backend development, use:
# NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_SQUARE_APPLICATION_ID=your-square-sandbox-application-id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your-square-sandbox-location-id
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox

# Backend private settings
PORT=5000
# In production/Vercel this must be a reachable MongoDB Atlas URI, not localhost.
MONGODB_URI=mongodb://127.0.0.1:27017/nexlance
# In production/Vercel this must be a long random secret.
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=12h
FRONTEND_URL=http://localhost:3000
# Use FRONTEND_URLS for multiple allowed CORS origins, separated by commas.
# Example: FRONTEND_URLS=https://your-project.vercel.app,https://your-custom-domain.com
FRONTEND_URLS=http://localhost:3000
# For one-domain Vercel deploys, use lax. Use none only for separate frontend/backend domains.
COOKIE_SAME_SITE=lax
NODE_ENV=development

# SMTP email settings for forgot-password OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-app-password
SMTP_FROM="Find Template <your-email@example.com>"
PASSWORD_RESET_OTP_EXPIRES_MINUTES=10

# Square sandbox payment settings
SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=your-square-sandbox-access-token
SQUARE_LOCATION_ID=your-square-sandbox-location-id
SQUARE_CURRENCY=USD
